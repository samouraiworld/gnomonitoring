# Reference only — DO NOT fill this in or copy to .env by hand.
#
# The real .env is GENERATED by bootstrap.sh (it is gitignored). This file just
# documents which variables it produces, so `docker compose` has what it needs.
# To create the real one, run:  make full-reinit   (or ./bootstrap.sh)
#
# P2P seed/persistent-peer lists, derived from each node's generated node_key.
# Format: <node_id>@<service>:26656,<node_id>@<service>:26656
# These have NO docker-compose default — an empty/missing .env means the
# validators can't find each other and the chain won't form.
SEEDS_VALIDATOR=<nodeid2>@validator2:26656,<nodeid3>@validator3:26656
SEEDS_VALIDATOR2=<nodeid1>@validator:26656,<nodeid3>@validator3:26656
SEEDS_VALIDATOR3=<nodeid1>@validator:26656,<nodeid2>@validator2:26656
SEEDS_VALIDATOR4=<nodeid1>@validator:26656,<nodeid2>@validator2:26656,<nodeid3>@validator3:26656

# Host user identity (uid:gid) so containers write gnoland-data as the host user
# and reinit-chain.sh can clean it without sudo. Defaults to 1000:1000 if unset.
DOCKER_USER=1000:1000

# Gnoland validator image used by docker-compose.yml (defaults to gno-validator:local).
# Override at bootstrap time: GNO_IMAGE=chain:test-13 ./bootstrap.sh
GNO_IMAGE=gno-validator:local

# Gnogenesis + examples image for genesis generation (must match GNO_IMAGE's source).
GNO_CONTRIBS_IMAGE=gno-contribs:local
